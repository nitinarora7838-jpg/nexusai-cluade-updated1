{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Production Preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "Next.js Build",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "build"],
      "port": null
    },
    {
      "name": "TypeCheck",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "typecheck"],
      "port": null
    },
    {
      "name": "Lint",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "lint"],
      "port": null
    }
  ]
}
